# -----------------------------------------------------------------------
# Power BI MCP Server - environment variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Azure AD Application (client) ID
# Register an app at https://portal.azure.com → Azure Active Directory →
# App registrations → New registration.
#
# Required settings on the app registration:
#   • Platform: Mobile and desktop applications
#   • Redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
#   • API Permissions (Delegated):
#       - https://analysis.windows.net/powerbi/api/Dataset.Read.All
#       - https://analysis.windows.net/powerbi/api/Workspace.Read.All
#     Grant admin consent if your tenant requires it.
POWERBI_CLIENT_ID=your-azure-ad-client-id-here

# Azure AD Tenant ID (optional — defaults to "organizations")
# Use "organizations" to allow any work/school account across all Azure AD tenants.
# Use your specific tenant ID (GUID or domain e.g. contoso.onmicrosoft.com) if
# the app is registered as single-tenant, or if you hit AADSTS50059.
# Find your tenant ID at: https://portal.azure.com → Azure Active Directory → Overview
POWERBI_TENANT_ID=organizations

# Output directory for large DAX query results (optional — defaults to "powerbi_output")
# When execute_dax returns more than 50 rows the full result is saved as a
# timestamped CSV file in this directory instead of being returned inline.
# This keeps the agent context window small for large datasets.
# Use an absolute path or a path relative to the server's working directory.
POWERBI_OUTPUT_DIR=powerbi_output

# -----------------------------------------------------------------------
# Miinto BI Knowledge Layer (optional — enables metric/search tools)
# -----------------------------------------------------------------------
# Railway-hosted knowledge layer API. Gives Claude access to canonical
# metric definitions, variant catalogs, dimension descriptions, and
# business opinions that enrich DAX query generation.
#
# Set KNOWLEDGE_API_BASE to the Railway service URL.
# Set KNOWLEDGE_API_KEY to the shared API key provisioned by the BI team.
# If these are not set, the knowledge-layer tools (search_knowledge,
# get_metric, list_knowledge_metrics, list_dimensions) will raise a
# RuntimeError when called — all other Power BI tools are unaffected.
KNOWLEDGE_API_BASE=https://<your-railway-url>
KNOWLEDGE_API_KEY=<shared-key>
