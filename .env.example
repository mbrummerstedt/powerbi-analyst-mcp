# -----------------------------------------------------------------------
# Power BI MCP Server - environment variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Azure AD Application (client) ID
# Register an app at https://portal.azure.com → Azure Active Directory →
# App registrations → New registration.
#
# Required settings on the app registration:
#   • Platform: Mobile and desktop applications
#   • Redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
#   • API Permissions (Delegated):
#       - https://analysis.windows.net/powerbi/api/Dataset.Read.All
#       - https://analysis.windows.net/powerbi/api/Workspace.Read.All
#     Grant admin consent if your tenant requires it.
POWERBI_CLIENT_ID=your-azure-ad-client-id-here

# Azure AD Tenant ID (optional — defaults to "organizations")
# Use "organizations" to allow any work/school account across all Azure AD tenants.
# Use your specific tenant ID (GUID or domain e.g. contoso.onmicrosoft.com) if
# the app is registered as single-tenant, or if you hit AADSTS50059.
# Find your tenant ID at: https://portal.azure.com → Azure Active Directory → Overview
POWERBI_TENANT_ID=organizations
